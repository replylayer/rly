{
  "name": "rly",
  "version": "0.7.13",
  "description": "CLI for ReplyLayer — safe email for AI agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/replylayer/rly.git"
  },
  "keywords": [
    "email",
    "ai",
    "agent",
    "cli",
    "replylayer",
    "mailbox",
    "mcp",
    "transactional"
  ],
  "bin": {
    "replylayer": "dist/bin/replylayer.js",
    "rly": "dist/bin/replylayer.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./api-client": "./dist/api-client.js",
    "./attachments": "./dist/attachments.js",
    "./auth": "./dist/auth.js",
    "./errors": "./dist/errors.js",
    "./types": "./dist/types.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CLI_GUIDE.md",
    "!dist/__tests__",
    "!dist/**/*.test.*"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "commander": "^14.0.3",
    "undici": "7.28.0"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "typescript": "6.0.3"
  }
}
